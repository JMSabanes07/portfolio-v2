---
import { Icon } from 'astro-icon/components'
import { pb } from '../lib/pocketbase'
import type { Project } from '../types/projects'
import PageSection from './PageSection.astro'
import ProjectModal from './ProjectModal'

let projects: Project[] = []
try {
  projects = await pb.collection('projects').getFullList<Project>({
    sort: '-year',
  })
} catch (error) {
  console.log(error)
}
---

<div section-id="projects" style={{ marginTop: '-6rem' }}>
  <PageSection title="My work" icon="projects">
    <div class="projects-container">
      {
        projects.map(project => (
          <article class="card" data-project-id={project.id}>
            <img
              src={`${import.meta.env.PUBLIC_POCKETBASE_IMAGES_URL}/${project.collectionName}/${project.id}/${project.thumbnail}`}
            />
            <div class="info">
              <h1>
                {project.name} <span class="year">{project.year}</span>
              </h1>
              <p>{project.short_desc}</p>
              <div class="icons">
                {project.icons.map(icon => (
                  <div class="icon">
                    <Icon name={icon} />
                    <span>{icon}</span>
                  </div>
                ))}
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </PageSection>
  <ProjectModal client:load projects={projects} />
</div>

<style>
  #projects {
    grid-area: body;
  }

  .projects-container {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }

  .card {
    display: grid;
    grid-template-columns: 0.7fr 2fr;
    grid-template-rows: 234px;
    align-items: flex-start;
    width: 602px;
    border-radius: 0.5rem;
    background-color: var(--card-color);
    position: relative;
    overflow: hidden;
    cursor: pointer;
  }

  .card::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    translate: -50% 0;
    width: 0%;
    height: 3px;
    background-color: var(--primary-color);
    filter: drop-shadow(0 0 10px var(--primary-color));
    transition: width 0.2s ease;
  }

  .card:hover::after {
    width: 100%;
  }

  .card .info {
    display: grid;
    grid-template-rows: auto 1fr auto;
    height: 100%;
    gap: 0.5rem;
    padding: 1rem 2rem;
  }

  .card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    /* border-radius: 0.5rem; */
    border-top-left-radius: 0.5rem;
    border-bottom-left-radius: 0.5rem;
  }

  @media (max-width: 700px) {
    .card {
      width: 100%;
      grid-template-columns: 1fr;
      grid-template-rows: 234px auto;
    }

    .card .info {
      padding: 2rem;
      gap: 1rem;
    }
  }

  .card h1 {
    font-size: 1.3rem;
  }
  .card h1 .year {
    font-size: 0.8rem;
    color: var(--text-color);
  }
  .card p {
    font-size: 1rem;
  }

  .card .icons {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .card .icons .icon {
    display: flex;
    align-items: center;
    gap: 0.3rem;
  }

  .card .icons .icon span {
    line-height: 0.9;
    font-size: 0.8rem;
    text-transform: capitalize;
  }
  .card .icons .icon [data-icon] {
    font-size: 1.2rem;
  }

:global(.modal-overlay) {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100vh;
    background-color: rgba(0, 0, 0, 0.85);
    backdrop-filter: blur(10px);
    display: flex;
    justify-content: center;
    align-items: flex-start;
    z-index: 9999;
    overflow-y: auto;
    animation: fadeIn 0.2s ease;
  }

  :global(.modal-overlay::-webkit-scrollbar) {
    padding-top: 1rem;
    padding-bottom: 1rem;
    width: 5px;
  }

  :global(.modal-overlay::-webkit-scrollbar-track) {
    background: rgba(255, 255, 255, 0.05);
  }

  :global(.modal-overlay::-webkit-scrollbar-thumb) {
    background: var(--primary-color);
    border-radius: 5px;
  }

  :global(.modal-overlay::-webkit-scrollbar-thumb:hover) {
    background: rgba(255, 255, 255, 0.093);
  }

  :global(.modal-container) {
    background-color: var(--card-color);
    backdrop-filter: blur(20px);
    border-radius: 1rem;
    width: 100%;
    max-width: 900px;
    max-height: 90vh;
    overflow-y: auto;
    position: relative;
    animation: slideUp 0.3s ease;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  :global(.modal-container::-webkit-scrollbar) {
    width: 8px;
  }

  :global(.modal-container::-webkit-scrollbar-track) {
    background: rgba(255, 255, 255, 0.05);
    border-radius: 4px;
  }

  :global(.modal-container::-webkit-scrollbar-thumb) {
    background: var(--primary-color);
    border-radius: 4px;
  }

  :global(.modal-container::-webkit-scrollbar-thumb:hover) {
    background: rgba(88, 255, 213, 0.8);
  }

  :global(.close-button) {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background-color: rgba(255, 255, 255, 0.1);
    border: none;
    color: var(--text-color);
    font-size: 2rem;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    cursor: pointer;
    transition:
      background-color 0.2s ease,
      color 0.2s ease;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
  }

  :global(.close-button:hover) {
    background-color: var(--primary-color);
    color: var(--text-inverted-color);
  }

  :global(.modal-content) {
    padding: 2rem;
    display: grid;
    gap: 2rem;
  }

  :global(.modal-header) {
    display: grid;
    gap: 1rem;
  }

  :global(.project-title) {
    font-size: 2rem;
    font-weight: 700;
  }

  :global(.project-title .year) {
    font-size: 1rem;
    color: var(--text-color);
    opacity: 0.7;
  }

  :global(.project-icons) {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  :global(.icon-badge) {
    background-color: rgba(255, 255, 255, 0.1);
    padding: 0.3rem 0.8rem;
    border-radius: 0.3rem;
    font-size: 0.9rem;
    text-transform: capitalize;
  }

  :global(.image-gallery) {
    position: relative;
    width: 100%;
    border-radius: 0.5rem;
    overflow: hidden;
    display: flex;
    justify-content: center;
    align-items: center;
    background-color: rgba(0, 0, 0, 0.3);
    min-height: 300px;
    max-height: 70vh;
  }

  :global(.gallery-image) {
    width: auto;
    height: auto;
    max-width: 100%;
    max-height: 50vh;
    object-fit: contain;
    border-radius: 0.5rem;
  }

  :global(.nav-button) {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background-color: rgba(0, 0, 0, 0.7);
    color: var(--text-color);
    border: none;
    font-size: 2.5rem;
    width: 50px;
    height: 50px;
    border-radius: 50%;
    cursor: pointer;
    transition:
      background-color 0.2s ease,
      color 0.2s ease;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  :global(.nav-button.prev) {
    left: 1rem;
  }

  :global(.nav-button.next) {
    right: 1rem;
  }

  :global(.nav-button:hover) {
    background-color: var(--primary-color);
    color: var(--text-inverted-color);
  }

  :global(.image-indicators) {
    position: absolute;
    bottom: 1rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 0.5rem;
  }

  :global(.indicator) {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background-color: rgba(255, 255, 255, 0.4);
    border: none;
    cursor: pointer;
    transition: background-color 0.2s ease;
    padding: 0;
  }

  :global(.indicator.active) {
    background-color: var(--primary-color);
  }

  :global(.indicator:hover) {
    background-color: var(--primary-color);
  }

  :global(.project-description) {
    padding: 1rem 0;
  }

  :global(.project-description p) {
    font-size: 1.1rem;
    line-height: 1.7;
  }

  :global(.project-link) {
    display: inline-block;
    background-color: var(--primary-color);
    color: var(--text-inverted-color);
    padding: 1rem 2rem;
    border-radius: 0.5rem;
    text-decoration: none;
    font-weight: 700;
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease;
  }

  :global(.project-link:hover) {
    transform: translateY(-2px);
    box-shadow: 0 0 20px var(--primary-color);
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  @keyframes slideUp {
    from {
      transform: translateY(20px);
      opacity: 0;
    }
    to {
      transform: translateY(0);
      opacity: 1;
    }
  }

  @media (max-width: 700px) {
    :global(.modal-content) {
      padding: 1.5rem;
    }

    :global(.project-title) {
      font-size: 1.5rem;
    }

    :global(.image-gallery) {
      min-height: 250px;
      max-height: 50vh;
    }

    :global(.gallery-image) {
      max-height: 50vh;
    }

    :global(.nav-button) {
      width: 40px;
      height: 40px;
      font-size: 2rem;
    }

    :global(.project-description p) {
      font-size: 1rem;
    }
  }
</style>
